{
  "compilerOptions": {
    "target": "ES2022",
     "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./user-stories",
    "rootDir": "./user-stories",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["user-stories/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
